# ── Flight MCP Server Configuration ──────────────────────────
# Copy this file to .env and adjust values as needed.

# Port the server listens on
PORT=8000

# API key required in the x-api-key header for all /tools/* requests
API_KEY=DEMO_KEY

# Human-readable service name (shown in logs and API metadata)
SERVICE_NAME=flight-mcp-server

# Path to the data directory (relative to the server/ directory)
DATA_DIR=data
